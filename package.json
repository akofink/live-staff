{
  "name": "live-staff",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "evidence:attended": "VITE_BUILD_SHA=$(git rev-parse HEAD) vite --host 0.0.0.0 --open /release-evidence.html",
    "build": "tsc -b && vite build && npm run check:performance-budget",
    "check:performance-budget": "node scripts/check-performance-budget.mjs",
    "lint": "eslint .",
    "test": "vitest run --exclude 'tests/browser/**' --exclude 'scripts/**/*.test.mjs'",
    "test:privacy": "node --test scripts/verify-privacy.test.mjs",
    "test:watch": "vitest --exclude 'tests/browser/**' --exclude 'scripts/**/*.test.mjs'",
    "verify:privacy": "node scripts/verify-privacy.mjs dist",
    "verify:production-privacy": "node scripts/verify-production-privacy.mjs",
    "evaluate:fixtures": "playwright install chromium && playwright test --config=playwright.fixture-evaluation.config.ts",
    "benchmark:detectors": "vite build --config vite.detector-bundles.config.ts && node scripts/measure-detector-bundles.mjs && playwright install chromium && playwright test --config=playwright.detector-benchmark.config.ts",
    "evaluate:performance": "playwright install chromium && playwright test --config=playwright.performance.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vexflow": "^5.0.0",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
